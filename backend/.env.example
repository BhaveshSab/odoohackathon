# ---------------------------------------------------------------------------
# AssetFlow backend environment — TEMPLATE (safe to commit)
# Copy this to `.env` and fill in real values. `.env` itself is git-ignored.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (get one free at https://neon.tech).
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign JWT access tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# API server port.
PORT=3000

# Comma-separated list of allowed frontend origins (Vite dev server default).
CORS_ORIGINS="http://localhost:5173"
